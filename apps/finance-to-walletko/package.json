    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "esbuild": "^0.25.0",
    "typescript": "^7.0.2",
    "vitest": "^3.0.0"
  }
}
